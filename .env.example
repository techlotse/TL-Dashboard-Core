# ─────────────────────────────────────────────────────────────────────────────
# TL-Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# Timezone for clock and scheduling (IANA format)
APP_TIMEZONE=Europe/Zurich

# ── Weather (Open-Meteo — no API key required) ────────────────────────────────
# GPS coordinates for weather location
WEATHER_LAT=47.3769
WEATHER_LON=8.5417
# Reserved for future use — leave as open-meteo
WEATHER_PROVIDER=open-meteo
# How often to refresh weather data (minutes)
REFRESH_WEATHER_MINUTES=30

# ── Swiss Public Transport (transport.opendata.ch — no API key required) ──────
# Exact station name as used by SBB/CFF/FFS (e.g. "Zürich HB", "Bern", "Basel SBB")
SBB_STATION_NAME=Zürich HB
# How often to refresh departure board (seconds)
REFRESH_TRANSPORT_SECONDS=60

# Optional commute route shown in the SBB widget.
# Leave COMMUTE_FROM_STATION blank to use SBB_STATION_NAME.
COMMUTE_ENABLED=true
COMMUTE_FROM_STATION=
COMMUTE_TO_STATION=
COMMUTE_DEPARTURE_TIME=07:30
COMMUTE_RETURN_TIME=17:30
COMMUTE_WINDOW_MINUTES=120
COMMUTE_MAX_OPTIONS=3

# ── Google Calendar ───────────────────────────────────────────────────────────

# OPTION A — iCal URL (easiest, no API key needed):
# Google Calendar → Settings → [your calendar] → "Secret address in iCal format"
# Copy the webcal:// or https:// link and paste it here.
CALENDAR_ICAL_URL=

# OPTION B — Google Calendar API (service account or OAuth):
# Your Google Calendar ID (found in Calendar Settings → Integrate calendar)
GOOGLE_CALENDAR_ID=

# SERVICE ACCOUNT (for Option B):
# Path to the service account JSON key file inside the container.
# Mount your local key file via volumes in docker-compose.yml.
# Default path below; change if you mount it elsewhere.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/run/secrets/google_sa_key.json

# OAUTH2 ALTERNATIVE (if not using service account):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# To get a refresh token: https://developers.google.com/oauthplayground/
# Scope needed: https://www.googleapis.com/auth/calendar.readonly

# How many days ahead to fetch calendar events from the API
CALENDAR_LOOKAHEAD_DAYS=14
# How many days of events to display in the widget (≤ CALENDAR_LOOKAHEAD_DAYS)
CALENDAR_DISPLAY_DAYS=14
# How often to refresh calendar (minutes)
REFRESH_CALENDAR_MINUTES=5

# ── Public Holidays (Nager.Date — no API key required) ────────────────────────
# ISO 3166-1 alpha-2 country code
HOLIDAY_COUNTRY=CH
# Canton codes (e.g. ZH, BE, GE, VD, TI) — filters cantonal holidays
# Leave blank to show only national holidays
HOLIDAY_TOWN_1=ZH
HOLIDAY_TOWN_2=
# How many upcoming holidays to display in the widget
HOLIDAYS_MAX_ITEMS=8

# ── RSS News Ticker ───────────────────────────────────────────────────────────
# Comma-separated list of RSS feed URLs
RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://www.srf.ch/news/bnf/rss/1646.rss
# How often to refresh feeds (minutes)
REFRESH_RSS_MINUTES=10
# Maximum headlines per feed
RSS_MAX_ITEMS=20
# How long each headline is displayed in the ticker (seconds)
RSS_ITEM_DURATION_SECONDS=10

# ── Background Slideshow ─────────────────────────────────────────────────────
# Path inside the container where background images are mounted
BACKGROUND_IMAGE_PATH=/app/backgrounds
# Seconds between photo changes in the background slideshow
BACKGROUND_INTERVAL_SECONDS=15

# ── METAR (Aviation Weather Center — no API key required) ────────────────────
# 4-letter ICAO airport code for the METAR widget (default: Zürich Airport)
METAR_ICAO=LSZH
# How often to refresh METAR data (minutes)
METAR_REFRESH_MINUTES=30

# ── Persistent settings storage ──────────────────────────────────────────────
# Container path where UI-saved settings.json is written
DATA_PATH=/app/data

# ── Internal ─────────────────────────────────────────────────────────────────
# Backend port (internal — exposed via nginx/reverse-proxy)
PORT=3001
NODE_ENV=production
